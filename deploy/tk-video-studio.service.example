[Unit]
Description=TK Video Studio API
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/projects/tk-video-studio/backend
# 读取 /projects/tk-video-studio/studio.config.json（部署时由 init-server-config.sh 生成）
ExecStart=/projects/tk-video-studio/.venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
